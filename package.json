{
  "name": "api-automation",
  "version": "1.0.0",
  "description": "API automation testing project using Mocha and Chai",
  "type": "module",
  "scripts": {
    "test": "mocha './*.test.js' --timeout 5000 --reporter spec",
    "test-report-html": "mocha './*.test.js' --reporter mocha-simple-html-reporter --reporter-options output=report.html",
    "test-report-json": "mocha './*.test.js' --reporter json > test-results.json"
  },
  "dependencies": {
    "node-fetch": "^3.3.1",
    "ajv": "^8.12.0"
  },
  "devDependencies": {
    "mocha": "^10.2.0",
    "chai": "^4.3.8",
    "mocha-simple-html-reporter": "^2.0.0"
  }
}
